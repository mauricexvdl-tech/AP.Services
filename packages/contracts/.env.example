# ═══════════════════════════════════════════════════════════
# APORIA Protocol – Environment Configuration
# ═══════════════════════════════════════════════════════════

# ─── Deployer Wallet ──────────────────────────────────────
# Private key of the deployer wallet (WITH 0x prefix)
# ⚠️  NEVER commit this file to git!
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── Alchemy API Key (Recommended) ───────────────────────
# Get a free API key from: https://dashboard.alchemy.com
# When set, Alchemy RPC URLs are used automatically for
# Base Sepolia and Base Mainnet (better reliability + enhanced APIs)
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY

# ─── Base Sepolia RPC (override, optional) ────────────────
# Leave empty to auto-use Alchemy URL when ALCHEMY_API_KEY is set
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ─── Base Mainnet RPC (override, optional) ────────────────
# Leave empty to auto-use Alchemy URL when ALCHEMY_API_KEY is set
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ─── Basescan API Key (for contract verification) ─────────
# Get it from: https://basescan.org/myapikey
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ─── Alchemy Notify (Webhooks) ────────────────────────────
# Generate in Alchemy Dashboard → Notify
# Required for: aporia webhooks setup
ALCHEMY_NOTIFY_AUTH_TOKEN=YOUR_NOTIFY_AUTH_TOKEN
